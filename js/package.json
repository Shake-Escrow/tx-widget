{
  "name": "@shake-defi/js",
  "version": "2.0.0",
  "description": "Token purchase platform frontend widget",
  "author": "Matthew Anderson",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shake-Escrow/tx-widget.git"
  },
  "keywords": [
    "crypto",
    "defi",
    "web3",
    "token",
    "widget"
  ],
  "files": [
    "dist",
    "index.d.ts"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "types": "./index.d.ts",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "browser": "dist/platform.js",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "browser": "./dist/platform.js"
    }
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "node build.js",
    "build:watch": "node build.js --watch",
    "build:dev": "node build.js --dev"
  },
  "dependencies": {
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.21.0"
  }
}
