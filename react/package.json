{
  "name": "@shake-defi/react",
  "version": "1.0.1",
  "description": "React component wrapper for the token purchase widget",
  "author": "Matthew Anderson",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shake-Escrow/tx-widget.git"
  },
  "keywords": [
    "crypto",
    "defi",
    "web3",
    "react",
    "widget"
  ],
  "files": [
    "dist",
    "index.d.ts"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "types": "./index.d.ts",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "esbuild src/index.jsx --bundle --format=esm --external:react --external:react-dom --external:@shake-defi/js --outfile=dist/index.js && esbuild src/index.jsx --bundle --format=cjs --external:react --external:react-dom --external:@shake-defi/js --outfile=dist/index.cjs"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@shake-defi/js": "^1.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.21.0"
  }
}
